{
  "id": null,
  "uid": "fish-fry-observability-v1",
  "title": "Fish Fry - App Observability",
  "tags": ["fish-fry", "observability", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus",
        "current": {
          "selected": true
        }
      },
      {
        "name": "namespace",
        "type": "query",
        "label": "Namespace",
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "query": "label_values(up, namespace)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "current": {
          "text": "fish-fry-orders-dev",
          "value": "fish-fry-orders-dev",
          "selected": true
        }
      },
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "query": "label_values(up{namespace=\"$namespace\"}, service)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "current": {
          "text": "fish-fry-orders-dev-api",
          "value": "fish-fry-orders-dev-api",
          "selected": true
        }
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Database Up (5m max)",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "max_over_time(fish_fry_database_up{namespace=\"$namespace\",service=\"$service\"}[5m])"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "DB Ping P95 (s)",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 6, "w": 12, "x": 6, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(fish_fry_database_ping_duration_seconds_bucket{namespace=\"$namespace\",service=\"$service\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "WebSocket Clients",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "fish_fry_websocket_clients{namespace=\"$namespace\",service=\"$service\"}",
          "legendFormat": "clients"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Rate by Status",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(http_requests_total{namespace=\"$namespace\",service=\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP 5xx Error Rate (%)",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 6 },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(http_requests_total{namespace=\"$namespace\",service=\"$service\",status=~\"5..\"}[$__rate_interval])) / clamp_min(sum(rate(http_requests_total{namespace=\"$namespace\",service=\"$service\"}[$__rate_interval])), 1)",
          "legendFormat": "5xx %"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Orders Created Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 6 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(fish_fry_orders_created_total{namespace=\"$namespace\",service=\"$service\"}[$__rate_interval])",
          "legendFormat": "orders/s"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Session Remaining (minutes)",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "refId": "A",
          "expr": "fish_fry_session_time_remaining_seconds{namespace=\"$namespace\",service=\"$service\"} / 60",
          "legendFormat": "minutes"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Active Session",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 14 },
      "targets": [
        {
          "refId": "A",
          "expr": "max_over_time(fish_fry_active_session{namespace=\"$namespace\",service=\"$service\"}[5m])"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "gray", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "No" }, "1": { "text": "Yes" } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Order Status Transitions",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 14 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (from, to) (rate(fish_fry_order_status_transitions_total{namespace=\"$namespace\",service=\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{from}} -> {{to}}"
        }
      ]
    }
  ]
}
